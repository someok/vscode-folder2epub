{
  "name": "vscode-folder2epub",
  "displayName": "Folder2EPUB",
  "description": "%extension.description%",
  "version": "1.1.0",
  "publisher": "someok",
  "license": "MIT",
  "type": "commonjs",
  "scripts": {
    "compile": "node scripts/build.mjs",
    "generate:icon": "node scripts/generate-icon.mjs",
    "watch": "node scripts/build.mjs --watch",
    "clean": "rimraf dist release",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "vscode:prepublish": "npm run compile",
    "package": "npm run compile && node scripts/package-vsix.mjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/someok/vscode-folder2epub"
  },
  "homepage": "https://github.com/someok/vscode-folder2epub",
  "bugs": {
    "url": "https://github.com/someok/vscode-folder2epub/issues"
  },
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "epub",
    "markdown",
    "txt",
    "ebook"
  ],
  "icon": "media/icon.png",
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "folder2epub.generateEpub",
        "title": "%command.generateEpub.title%",
        "category": "Folder2EPUB"
      },
      {
        "command": "folder2epub.initEpub",
        "title": "%command.initEpub.title%",
        "category": "Folder2EPUB"
      },
      {
        "command": "folder2epub.createT2eIgnore",
        "title": "%command.createT2eIgnore.title%",
        "category": "Folder2EPUB"
      },
      {
        "command": "folder2epub.configureDefaultAuthor",
        "title": "%command.configureDefaultAuthor.title%",
        "category": "Folder2EPUB"
      }
    ],
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "folder2epub.defaultAuthor": {
          "type": "string",
          "default": "",
          "scope": "window",
          "markdownDescription": "%config.defaultAuthor.description%"
        }
      }
    },
    "menus": {
      "explorer/context": [
        {
          "command": "folder2epub.generateEpub",
          "when": "explorerResourceIsFolder && resourceScheme == file",
          "group": "z_folder2epub@997"
        },
        {
          "command": "folder2epub.createT2eIgnore",
          "when": "explorerResourceIsFolder && resourceScheme == file",
          "group": "z_folder2epub@998"
        },
        {
          "command": "folder2epub.initEpub",
          "when": "explorerResourceIsFolder && resourceScheme == file",
          "group": "z_folder2epub@999"
        }
      ]
    }
  },
  "dependencies": {
    "ignore": "^7.0.5",
    "jszip": "^3.10.1",
    "markdown-it": "^14.1.1",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.116.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.21.0",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  }
}
